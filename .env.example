# AIDE v5 Configuration
# =====================
# Remote LLM providers (Gemini primary, Groq fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
AIDE_ENABLE_REMOTE_LLM=1
AIDE_GROQ_MODEL=llama-3.1-8b-instant
AIDE_LLM_HTTP_TIMEOUT_SECONDS=45

# API server
AIDE_API_CORS_ORIGINS=*

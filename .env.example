# AIDE v5 Configuration
# =====================
# Remote LLM providers (free-first OpenRouter, then Gemini/Groq, optional xAI)
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
XAI_API_KEY=your_xai_api_key_here
AIDE_ENABLE_REMOTE_LLM=1
AIDE_USE_LLM_INTENT=1
AIDE_USE_LLM_RESEARCH=1
AIDE_USE_LLM_GENERATION=1
AIDE_OPENROUTER_MODEL=openai/gpt-oss-20b:free
AIDE_OPENROUTER_ROUTER_MODEL=openrouter/free
AIDE_GEMINI_MODEL=gemini-2.5-flash
AIDE_GROQ_MODEL=llama-3.1-8b-instant
AIDE_XAI_MODEL=grok-3-mini
AIDE_LLM_PROVIDER_ORDER=openrouter,openrouter_router,gemini,groq,xai
AIDE_LLM_JSON_PROVIDER_ORDER=openrouter,openrouter_router,groq,gemini,xai
AIDE_OPENROUTER_TITLE=AIDE v5
AIDE_OPENROUTER_REFERER=http://localhost:9000/app/
AIDE_LLM_HTTP_TIMEOUT_SECONDS=45

# API server
AIDE_API_CORS_ORIGINS=*
